<section id="auth" class="mb-5">
    <div class="mb-3">
        <h2 class="h4 fw-bold mb-1">Auth</h2>
        <p class="text-secondary mb-0">Authentication endpoints.</p>
    </div>

    <div class="vstack gap-4">
        <article id="auth-login" class="card border-0 rounded-3 shadow-sm overflow-hidden">
            <div class="card-body p-0">
                <div class="p-4 border-bottom">
                    <div class="d-flex flex-column flex-md-row align-items-md-start gap-3">
                        <span class="badge text-bg-success px-3 py-2 align-self-start">POST</span>
                        <div class="flex-grow-1">
                            <div class="d-flex flex-column flex-xl-row gap-2 justify-content-between">
                                <div>
                                    <h3 class="h5 fw-semibold mb-1">Login</h3>
                                    <code class="fs-6">/auth/login</code>
                                </div>
                                <span class="badge text-bg-light border align-self-start">Public</span>
                            </div>
                            <p class="text-secondary mt-3 mb-0">Authenticate user by email and password.</p>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Parameters</div>
                        <div class="text-secondary">None</div>
                    </div>

                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Request Body</div>
                        <div class="border rounded bg-body p-3">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge text-bg-light border">application/json</span>
                                <span class="badge text-bg-light border">required: Yes</span>
                                <span class="badge text-bg-light border">schema: LoginRequest</span>
                            </div>
                            <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "email": "tva@example.com",
  "password": "123456"
}</code></pre>
                        </div>
                    </div>

                    <div>
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Responses</div>
                        <div class="vstack gap-3">
                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-success me-2">200</span>
                                    <span class="fw-semibold">Login successful</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": {
    "user": {
      "id": 1,
      "full_name": "tva",
      "email": "tva@example.com",
      "created_at": "2026-04-01T09:16:38.013Z"
    },
    "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "expiresIn": {
      "accessToken": "15m"
    }
  },
  "meta": {
    "timestamp": "2026-04-01T09:34:06.175Z"
  },
  "error": null
}</code></pre>
                            </div>

                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-warning me-2">400</span>
                                    <span class="fw-semibold">Invalid request data</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": null,
  "meta": {
    "timestamp": "2026-04-01T09:44:00.220Z"
  },
  "error": {
    "code": 400,
    "message": "Invalid request data",
    "details": [
      {
        "field": "password",
        "issue": "Invalid input: expected string, received undefined"
      }
    ]
  }
}</code></pre>
                            </div>

                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-warning me-2">401</span>
                                    <span class="fw-semibold">Incorrect email or password</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": null,
  "meta": {
    "timestamp": "2026-04-01T09:43:26.235Z"
  },
  "error": {
    "code": 401,
    "message": "Incorrect email or password",
    "details": null
  }
}</code></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </article>

        <article id="auth-signup" class="card border-0 rounded-3 shadow-sm overflow-hidden">
            <div class="card-body p-0">
                <div class="p-4 border-bottom">
                    <div class="d-flex flex-column flex-md-row align-items-md-start gap-3">
                        <span class="badge text-bg-success px-3 py-2 align-self-start">POST</span>
                        <div class="flex-grow-1">
                            <div class="d-flex flex-column flex-xl-row gap-2 justify-content-between">
                                <div>
                                    <h3 class="h5 fw-semibold mb-1">Sign up</h3>
                                    <code class="fs-6">/auth/signup</code>
                                </div>
                                <span class="badge text-bg-light border align-self-start">Public</span>
                            </div>
                            <p class="text-secondary mt-3 mb-0">Register a new user account.</p>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Parameters</div>
                        <div class="text-secondary">None</div>
                    </div>

                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Request Body</div>
                        <div class="border rounded bg-body p-3">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge text-bg-light border">application/json</span>
                                <span class="badge text-bg-light border">required: Yes</span>
                                <span class="badge text-bg-light border">schema: SignupRequest</span>
                            </div>
                            <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "full_name": "ntc",
  "email": "ntc@example.com",
  "password": "pWd123",
  "passwordConfirm": "pWd123"
}</code></pre>
                        </div>
                    </div>

                    <div>
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Responses</div>
                        <div class="vstack gap-3">
                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-success me-2">200</span>
                                    <span class="fw-semibold">Signup successful</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": {
    "user": {
      "id": 2,
      "full_name": "ntc",
      "email": "ntc@example.com",
      "created_at": "2026-04-01T09:41:51.397Z"
    },
    "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "expiresIn": {
      "accessToken": "15m"
    }
  },
  "meta": {
    "timestamp": "2026-04-01T09:41:51.402Z"
  },
  "error": null
}</code></pre>
                            </div>

                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-warning me-2">400</span>
                                    <span class="fw-semibold">Invalid request data or email already exists</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": null,
  "meta": {
    "timestamp": "2026-04-01T09:48:12.987Z"
  },
  "error": {
    "code": 400,
    "message": "User with this email already exists",
    "details": null
  }
}</code></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </article>

        <article id="auth-logout" class="card border-0 rounded-3 shadow-sm overflow-hidden">
            <div class="card-body p-0">
                <div class="p-4 border-bottom">
                    <div class="d-flex flex-column flex-md-row align-items-md-start gap-3">
                        <span class="badge text-bg-success px-3 py-2 align-self-start">POST</span>
                        <div class="flex-grow-1">
                            <div class="d-flex flex-column flex-xl-row gap-2 justify-content-between">
                                <div>
                                    <h3 class="h5 fw-semibold mb-1">Logout</h3>
                                    <code class="fs-6">/auth/logout</code>
                                </div>
                                <span class="badge text-bg-light border align-self-start">Bearer Token</span>
                            </div>
                            <p class="text-secondary mt-3 mb-0">Logout current user.</p>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Parameters</div>
                        <div class="text-secondary">None</div>
                    </div>

                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Request Body</div>
                        <div class="text-secondary">None</div>
                    </div>

                    <div>
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Responses</div>
                        <div class="vstack gap-3">
                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-success me-2">200</span>
                                    <span class="fw-semibold">Logout successful</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": {
    "message": "Logged out successfully"
  },
  "meta": {
    "timestamp": "2026-04-01T09:45:50.530Z"
  },
  "error": null
}</code></pre>
                            </div>

                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-warning me-2">401</span>
                                    <span class="fw-semibold">Unauthorized</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": null,
  "meta": {
    "timestamp": "2026-04-01T09:56:59.231Z"
  },
  "error": {
    "code": 401,
    "message": "You are not logged in! Please log in to get access.",
    "details": null
  }
}</code></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </article>

        <article id="auth-me" class="card border-0 rounded-3 shadow-sm overflow-hidden">
            <div class="card-body p-0">
                <div class="p-4 border-bottom">
                    <div class="d-flex flex-column flex-md-row align-items-md-start gap-3">
                        <span class="badge text-bg-primary px-3 py-2 align-self-start">GET</span>
                        <div class="flex-grow-1">
                            <div class="d-flex flex-column flex-xl-row gap-2 justify-content-between">
                                <div>
                                    <h3 class="h5 fw-semibold mb-1">Get current user</h3>
                                    <code class="fs-6">/auth/me</code>
                                </div>
                                <span class="badge text-bg-light border align-self-start">Bearer Token</span>
                            </div>
                            <p class="text-secondary mt-3 mb-0">Get profile of currently authenticated user.</p>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Parameters</div>
                        <div class="text-secondary">None</div>
                    </div>

                    <div class="mb-4">
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Request Body</div>
                        <div class="text-secondary">None</div>
                    </div>

                    <div>
                        <div class="text-secondary small fw-bold text-uppercase mb-2">Responses</div>
                        <div class="vstack gap-3">
                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-success me-2">200</span>
                                    <span class="fw-semibold">Current user fetched successfully</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": {
    "user": {
      "id": 1,
      "full_name": "tva",
      "email": "tva@example.com",
      "created_at": "2026-04-01T09:16:38.013Z"
    }
  },
  "meta": {
    "timestamp": "2026-04-01T09:57:23.386Z"
  },
  "error": null
}</code></pre>
                            </div>

                            <div class="border rounded bg-body p-3">
                                <div class="mb-3">
                                    <span class="badge text-bg-warning me-2">401</span>
                                    <span class="fw-semibold">Unauthorized</span>
                                </div>
                                <pre class="bg-dark text-light rounded p-3 overflow-auto m-0"><code class="text-light">{
  "data": null,
  "meta": {
    "timestamp": "2026-04-01T09:56:59.231Z"
  },
  "error": {
    "code": 401,
    "message": "You are not logged in! Please log in to get access.",
    "details": null
  }
}</code></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>